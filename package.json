{
  "name": "ecg-scheduler-web-version",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "node scripts/run-with-env-local.js prisma generate && next build",
    "start": "next start",
    "smoke": "node scripts/smoke-test.js",
    "lint": "next lint",
    "db:migrate": "node scripts/run-with-env-local.js prisma migrate dev",
    "db:deploy": "node scripts/run-with-env-local.js prisma migrate deploy",
    "db:push": "node scripts/run-with-env-local.js prisma db push",
    "db:studio": "node scripts/run-with-env-local.js prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node scripts/run-with-env-local.js node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.30",
    "postcss": "^8.4.41",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
