generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Hospital {
  id            String         @id @default(cuid())
  name          String         @unique
  isActive      Boolean        @default(true)
  departments   Department[]
  units         Unit[]
  users         User[]
  scheduleTasks ScheduleTask[]
  feedback      Feedback[]
  auditLogs     AuditLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([name])
}

model Department {
  id               String                  @id @default(cuid())
  hospitalId       String?
  hospital         Hospital?               @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  name             String
  isActive         Boolean                 @default(true)
  units            Unit[]
  users            User[]
  scheduleTasks    ScheduleTask[]
  scheduleDoctors  ScheduleDoctor[]
  unavailableTimes DoctorUnavailableTime[]
  requirements     ScheduleRequirement[]
  assignments      ScheduleAssignment[]
  conflicts        ScheduleConflict[]
  accessCodes      DepartmentAccessCode[]
  guestSessions    GuestSession[]
  feedback         Feedback[]
  auditLogs        AuditLog[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([hospitalId, name])
  @@index([hospitalId])
  @@index([name])
}

model Unit {
  id              String         @id @default(cuid())
  hospitalId      String?
  hospital        Hospital?      @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId    String
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name            String
  isActive        Boolean        @default(true)
  createdByUserId String?
  createdByUser   User?          @relation("CreatedUnits", fields: [createdByUserId], references: [id], onDelete: SetNull)
  users           User[]
  scheduleTasks   ScheduleTask[]
  feedback        Feedback[]
  auditLogs       AuditLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([departmentId, name])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([createdByUserId])
}

model User {
  id                   String                @id @default(cuid())
  username             String                @unique
  passwordHash         String
  role                 String
  displayName          String?
  phone                String?               @unique
  email                String?               @unique
  hospitalId           String?
  hospital             Hospital?             @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId         String?
  department           Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId               String?
  unit                 Unit?                 @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdUnits         Unit[]                @relation("CreatedUnits")
  createdTasks         ScheduleTask[]
  sessions             Session[]
  feedback             Feedback[]
  organizationRequests OrganizationRequest[]
  auditLogs            AuditLog[]
  mustChangePassword   Boolean               @default(false)
  isActive             Boolean               @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model DepartmentAccessCode {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  codeHash     String     @unique
  expiresAt    DateTime
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
  @@index([expiresAt])
}

model GuestSession {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([departmentId])
  @@index([expiresAt])
}

model ScheduleTask {
  id               String                  @id @default(cuid())
  hospitalId       String?
  hospital         Hospital?               @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId     String
  department       Department              @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  unitId           String?
  unit             Unit?                   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdByUserId  String?
  createdByUser    User?                   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  weekStartDate    DateTime
  weekEndDate      DateTime
  mode             String
  status           String                  @default("DRAFT")
  doctors          ScheduleDoctor[]
  unavailableTimes DoctorUnavailableTime[]
  requirements     ScheduleRequirement[]
  assignments      ScheduleAssignment[]
  conflicts        ScheduleConflict[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([createdByUserId])
  @@index([weekStartDate])
  @@index([status])
}

model ScheduleDoctor {
  id               String                  @id @default(cuid())
  departmentId     String?
  department       Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId   String
  scheduleTask     ScheduleTask            @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  name             String
  doctorType       String
  unavailableTimes DoctorUnavailableTime[]
  assignments      ScheduleAssignment[]
  createdAt        DateTime                @default(now())

  @@unique([scheduleTaskId, name])
  @@index([departmentId])
  @@index([scheduleTaskId])
}

model DoctorUnavailableTime {
  id             String         @id @default(cuid())
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId String
  scheduleTask   ScheduleTask   @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         ScheduleDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date           DateTime
  weekday        Int
  timeSlot       String
  reason         String?
  createdAt      DateTime       @default(now())

  @@unique([scheduleTaskId, doctorId, date, timeSlot])
  @@index([departmentId])
  @@index([scheduleTaskId, doctorId])
  @@index([date, timeSlot])
}

model ScheduleRequirement {
  id              String       @id @default(cuid())
  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId  String
  scheduleTask    ScheduleTask @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  date            DateTime
  weekday         Int
  timeSlot        String
  enabled         Boolean      @default(true)
  roomNumber      Int
  requiredDoctors Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([scheduleTaskId, date, timeSlot, roomNumber])
  @@index([departmentId])
  @@index([scheduleTaskId])
  @@index([date, timeSlot])
}

model ScheduleAssignment {
  id             String         @id @default(cuid())
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId String
  scheduleTask   ScheduleTask   @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  date           DateTime
  weekday        Int
  roomNumber     Int
  timeSlot       String
  doctorId       String
  doctor         ScheduleDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  locked         Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([scheduleTaskId, date, timeSlot, doctorId])
  @@index([departmentId])
  @@index([scheduleTaskId, date, timeSlot])
  @@index([scheduleTaskId, roomNumber])
}

model ScheduleConflict {
  id             String       @id @default(cuid())
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId String
  scheduleTask   ScheduleTask @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  date           DateTime
  weekday        Int
  roomNumber     Int
  timeSlot       String
  conflictType   String
  missingCount   Int?
  description    String
  severity       String       @default("WARNING")
  createdAt      DateTime     @default(now())

  @@index([departmentId])
  @@index([scheduleTaskId])
  @@index([date, timeSlot])
}

model Feedback {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalId   String?
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  type         String
  title        String
  content      String
  pageUrl      String?
  contact      String?
  status       String      @default("NEW")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([status])
  @@index([type])
}

model OrganizationRequest {
  id              String   @id @default(cuid())
  requesterUserId String?
  requesterUser   User?    @relation(fields: [requesterUserId], references: [id], onDelete: SetNull)
  hospitalName    String
  departmentName  String
  applicantName   String
  contact         String
  note            String?
  status          String   @default("NEW")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([requesterUserId])
  @@index([status])
}

model AuditLog {
  id           String      @id @default(cuid())
  actorUserId  String?
  actorUser    User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  hospitalId   String?
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  action       String
  targetType   String
  targetId     String?
  beforeJson   Json?
  afterJson    Json?
  reason       String?
  ip           String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([actorUserId])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([action])
  @@index([createdAt])
}
