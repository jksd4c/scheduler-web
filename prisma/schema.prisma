generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Hospital {
  id            String         @id @default(cuid())
  name          String         @unique
  isActive      Boolean        @default(true)
  departments   Department[]
  units         Unit[]
  users         User[]
  scheduleTasks ScheduleTask[]
  feedback      Feedback[]
  auditLogs     AuditLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([name])
}

model Department {
  id               String                  @id @default(cuid())
  hospitalId       String?
  hospital         Hospital?               @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  name             String
  isActive         Boolean                 @default(true)
  units            Unit[]
  users            User[]
  scheduleTasks    ScheduleTask[]
  scheduleDoctors  ScheduleDoctor[]
  unavailableTimes DoctorUnavailableTime[]
  requirements     ScheduleRequirement[]
  assignments      ScheduleAssignment[]
  conflicts        ScheduleConflict[]
  accessCodes      DepartmentAccessCode[]
  guestSessions    GuestSession[]
  feedback         Feedback[]
  auditLogs        AuditLog[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([hospitalId, name])
  @@index([hospitalId])
  @@index([name])
}

model Unit {
  id              String         @id @default(cuid())
  hospitalId      String?
  hospital        Hospital?      @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId    String
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name            String
  isActive        Boolean        @default(true)
  createdByUserId String?
  createdByUser   User?          @relation("CreatedUnits", fields: [createdByUserId], references: [id], onDelete: SetNull)
  users           User[]
  scheduleTasks   ScheduleTask[]
  staffTags       StaffTag[]
  staffProfiles   StaffProfile[]
  shiftTypes      ShiftType[]
  feedback        Feedback[]
  auditLogs       AuditLog[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([departmentId, name])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([createdByUserId])
}

model User {
  id                   String                @id @default(cuid())
  username             String                @unique
  passwordHash         String
  role                 String
  displayName          String?
  phone                String?               @unique
  email                String?               @unique
  hospitalId           String?
  hospital             Hospital?             @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId         String?
  department           Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId               String?
  unit                 Unit?                 @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdUnits         Unit[]                @relation("CreatedUnits")
  createdTasks         ScheduleTask[]
  staffProfiles        StaffProfile[]
  sessions             Session[]
  feedback             Feedback[]
  organizationRequests OrganizationRequest[]
  auditLogs            AuditLog[]
  mustChangePassword   Boolean               @default(false)
  isActive             Boolean               @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@index([role, isActive])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model DepartmentAccessCode {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  codeHash     String     @unique
  expiresAt    DateTime
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
  @@index([expiresAt])
}

model GuestSession {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([departmentId])
  @@index([expiresAt])
}

model ScheduleTask {
  id               String                  @id @default(cuid())
  hospitalId       String?
  hospital         Hospital?               @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId     String
  department       Department              @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  unitId           String?
  unit             Unit?                   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdByUserId  String?
  createdByUser    User?                   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  weekStartDate    DateTime
  weekEndDate      DateTime
  mode             String
  scheduleMode     String                  @default("MEDTECH_ROOM")
  status           String                  @default("DRAFT")
  doctors          ScheduleDoctor[]
  participants     ScheduleParticipant[]
  unavailableTimes DoctorUnavailableTime[]
  requirements     ScheduleRequirement[]
  assignments      ScheduleAssignment[]
  conflicts        ScheduleConflict[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([createdByUserId])
  @@index([weekStartDate])
  @@index([status])
  @@index([scheduleMode])
  @@index([createdAt])
  @@index([unitId, createdAt])
  @@index([departmentId, createdAt])
  @@index([status, createdAt])
}

model StaffPool {
  id              String   @id @default(cuid())
  hospitalId      String?
  departmentId    String
  unitId          String
  scheduleTaskId  String?
  poolType        String
  name            String
  startDate       DateTime?
  endDate         DateTime?
  active          Boolean  @default(true)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([scheduleTaskId])
  @@index([poolType])
  @@index([active])
  @@index([unitId, poolType])
}

model RosterEntry {
  id                  String   @id @default(cuid())
  hospitalId          String?
  departmentId        String
  unitId              String
  scheduleTaskId      String?
  staffPoolId         String?
  staffProfileId      String?
  userId              String?
  poolType            String
  expectedName        String
  expectedPhone       String?
  staffType           String?
  identityTagIds      Json?
  startDate           DateTime?
  endDate             DateTime?
  status              String   @default("WAITING_JOIN")
  includeInScheduling Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([scheduleTaskId])
  @@index([staffPoolId])
  @@index([staffProfileId])
  @@index([userId])
  @@index([poolType])
  @@index([status])
  @@index([includeInScheduling])
  @@index([unitId, status])
  @@index([scheduleTaskId, status])
}

model JoinCode {
  id              String    @id @default(cuid())
  hospitalId      String?
  departmentId    String
  unitId          String
  scheduleTaskId  String?
  staffPoolId     String?
  codeHash        String    @unique
  roleToGrant     String    @default("MEMBER")
  expiresAt       DateTime
  active          Boolean   @default(true)
  maxUses         Int?
  useCount        Int       @default(0)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?

  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([scheduleTaskId])
  @@index([staffPoolId])
  @@index([expiresAt])
  @@index([active])
}

model JoinClaim {
  id               String    @id @default(cuid())
  joinCodeId       String
  userId           String
  rosterEntryId    String?
  hospitalId       String?
  departmentId     String
  unitId           String
  scheduleTaskId   String?
  staffPoolId      String?
  inputName        String
  inputPhone       String
  matchStatus      String
  reviewStatus     String    @default("PENDING")
  createdAt        DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?
  rejectReason     String?

  @@index([joinCodeId])
  @@index([userId])
  @@index([rosterEntryId])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([scheduleTaskId])
  @@index([staffPoolId])
  @@index([matchStatus])
  @@index([reviewStatus])
  @@index([createdAt])
}

model ScheduleDoctor {
  id                 String                  @id @default(cuid())
  departmentId       String?
  department         Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId     String
  scheduleTask       ScheduleTask            @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  staffProfileId     String?
  staffProfile       StaffProfile?           @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  name               String
  doctorType         String
  active             Boolean                 @default(true)
  tagSnapshotJson    Json?
  policySnapshotJson Json?
  participant        ScheduleParticipant?
  unavailableTimes   DoctorUnavailableTime[]
  assignments        ScheduleAssignment[]
  createdAt          DateTime                @default(now())

  @@unique([scheduleTaskId, name])
  @@index([departmentId])
  @@index([scheduleTaskId])
  @@index([staffProfileId])
}

model DoctorUnavailableTime {
  id             String         @id @default(cuid())
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId String
  scheduleTask   ScheduleTask   @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         ScheduleDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date           DateTime
  weekday        Int
  timeSlot       String
  reason         String?
  createdAt      DateTime       @default(now())

  @@unique([scheduleTaskId, doctorId, date, timeSlot])
  @@index([departmentId])
  @@index([scheduleTaskId, doctorId])
  @@index([date, timeSlot])
}

model ScheduleRequirement {
  id              String       @id @default(cuid())
  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId  String
  scheduleTask    ScheduleTask @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  date            DateTime
  weekday         Int
  timeSlot        String
  shiftTypeId     String?
  shiftType       ShiftType?   @relation(fields: [shiftTypeId], references: [id], onDelete: SetNull)
  enabled         Boolean      @default(true)
  roomNumber      Int
  requiredDoctors Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([scheduleTaskId, date, timeSlot, roomNumber])
  @@index([departmentId])
  @@index([scheduleTaskId])
  @@index([shiftTypeId])
  @@index([date, timeSlot])
}

model StaffTag {
  id               String                 @id @default(cuid())
  unitId           String
  unit             Unit                   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name             String
  category         String                 @default("CUSTOM")
  color            String?
  active           Boolean                @default(true)
  sortOrder        Int                    @default(0)
  policy           StaffTagPolicy?
  staffProfileTags StaffProfileTag[]
  shiftTypeRules   ShiftTypeRequiredTag[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([unitId, name])
  @@index([unitId])
  @@index([category])
  @@index([active])
  @@index([unitId, active])
}

model StaffTagPolicy {
  id                          String   @id @default(cuid())
  staffTagId                  String   @unique
  staffTag                    StaffTag @relation(fields: [staffTagId], references: [id], onDelete: Cascade)
  participatesInScheduling    Boolean  @default(true)
  canWorkDayShift             Boolean?
  canWorkNightShift           Boolean?
  canWorkWeekend              Boolean?
  canWorkHoliday              Boolean?
  canWorkFirstLine            Boolean?
  canWorkSecondLine           Boolean?
  canWorkEmergency            Boolean?
  canWorkOnCall               Boolean?
  canWorkBackup               Boolean?
  canWorkIndependently        Boolean?
  maxShiftsPerWeek            Int?
  maxWorkDaysPerWeek          Int?
  maxShiftsPerMonth           Int?
  maxNightShiftsPerMonth      Int?
  maxWeekendShiftsPerMonth    Int?
  maxHolidayShiftsPerMonth    Int?
  maxConsecutiveWorkDays      Int?
  allowConsecutiveNightShifts Boolean?
  allowDayAndNightSameDay     Boolean?
  allowDayAfterNightShift     Boolean?
  minRestHoursAfterNightShift Int?
  schedulingMode              String   @default("NORMAL")
  targetShiftsPerPeriod       Int?
  maxShiftsPerPeriod          Int?
  workloadFactor              Float    @default(1.0)
  countInFairness             Boolean  @default(true)
  note                        String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model StaffProfile {
  id              String                @id @default(cuid())
  unitId          String
  unit            Unit                  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName     String
  phone           String?
  email           String?
  active          Boolean               @default(true)
  note            String?
  tags            StaffProfileTag[]
  scheduleDoctors ScheduleDoctor[]
  participants    ScheduleParticipant[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([unitId, displayName])
  @@unique([unitId, phone])
  @@unique([unitId, email])
  @@index([unitId])
  @@index([userId])
  @@index([active])
  @@index([unitId, active])
}

model StaffProfileTag {
  id             String       @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  staffTagId     String
  staffTag       StaffTag     @relation(fields: [staffTagId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([staffProfileId, staffTagId])
  @@index([staffProfileId])
  @@index([staffTagId])
}

model ScheduleParticipant {
  id                 String          @id @default(cuid())
  scheduleTaskId     String
  scheduleTask       ScheduleTask    @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  scheduleDoctorId   String?         @unique
  scheduleDoctor     ScheduleDoctor? @relation(fields: [scheduleDoctorId], references: [id], onDelete: Cascade)
  staffProfileId     String?
  staffProfile       StaffProfile?   @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  displayName        String
  active             Boolean         @default(true)
  tagSnapshotJson    Json?
  policySnapshotJson Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([scheduleTaskId, displayName])
  @@index([scheduleTaskId])
  @@index([staffProfileId])
  @@index([active])
}

model ShiftType {
  id             String                 @id @default(cuid())
  unitId         String
  unit           Unit                   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name           String
  category       String                 @default("CUSTOM")
  isNight        Boolean                @default(false)
  workloadWeight Float                  @default(1.0)
  startTime      String?
  endTime        String?
  color          String?
  active         Boolean                @default(true)
  requiredTags   ShiftTypeRequiredTag[]
  requirements   ScheduleRequirement[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([unitId, name])
  @@index([unitId])
  @@index([category])
  @@index([active])
  @@index([unitId, active])
}

model ShiftTypeRequiredTag {
  id              String    @id @default(cuid())
  shiftTypeId     String
  shiftType       ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)
  staffTagId      String
  staffTag        StaffTag  @relation(fields: [staffTagId], references: [id], onDelete: Cascade)
  requirementType String
  createdAt       DateTime  @default(now())

  @@unique([shiftTypeId, staffTagId, requirementType])
  @@index([shiftTypeId])
  @@index([staffTagId])
  @@index([requirementType])
}

model ScheduleAssignment {
  id             String         @id @default(cuid())
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId String
  scheduleTask   ScheduleTask   @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  date           DateTime
  weekday        Int
  roomNumber     Int
  timeSlot       String
  doctorId       String
  doctor         ScheduleDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  locked         Boolean        @default(false)
  manualOverride Boolean        @default(false)
  overrideReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([scheduleTaskId, date, timeSlot, doctorId])
  @@index([departmentId])
  @@index([scheduleTaskId, date, timeSlot])
  @@index([scheduleTaskId, roomNumber])
  @@index([scheduleTaskId, manualOverride])
  @@index([doctorId])
}

model ScheduleConflict {
  id             String       @id @default(cuid())
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  scheduleTaskId String
  scheduleTask   ScheduleTask @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  date           DateTime
  weekday        Int
  roomNumber     Int
  timeSlot       String
  conflictType   String
  missingCount   Int?
  description    String
  severity       String       @default("WARNING")
  createdAt      DateTime     @default(now())

  @@index([departmentId])
  @@index([scheduleTaskId])
  @@index([scheduleTaskId, severity])
  @@index([date, timeSlot])
}

model Feedback {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalId   String?
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  type         String
  title        String
  content      String
  pageUrl      String?
  contact      String?
  status       String      @default("NEW")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([unitId, createdAt])
  @@index([status, createdAt])
}

model MemberFeedback {
  id                  String   @id @default(cuid())
  userId              String
  joinClaimId         String?
  rosterEntryId       String?
  scheduleTaskId      String?
  hospitalId          String?
  departmentId        String?
  unitId              String?
  title               String?
  message             String?
  canWorkShiftTypeIds Json?
  status              String   @default("WAITING_IDENTITY_CONFIRMATION")
  effective           Boolean  @default(false)
  anomalyStatus       String?
  reviewedAt          DateTime?
  reviewedByUserId    String?
  reviewReason        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  unavailableTimes    MemberFeedbackUnavailableTime[]

  @@index([userId])
  @@index([joinClaimId])
  @@index([rosterEntryId])
  @@index([scheduleTaskId])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([status])
  @@index([effective])
  @@index([createdAt])
  @@index([unitId, createdAt])
  @@index([scheduleTaskId, effective])
}

model MemberFeedbackUnavailableTime {
  id         String         @id @default(cuid())
  feedbackId String
  feedback   MemberFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  date       DateTime
  timeSlot   String
  reason     String?
  createdAt  DateTime       @default(now())

  @@index([feedbackId])
  @@index([date, timeSlot])
}

model OrganizationRequest {
  id              String   @id @default(cuid())
  requesterUserId String?
  requesterUser   User?    @relation(fields: [requesterUserId], references: [id], onDelete: SetNull)
  hospitalName    String
  departmentName  String
  applicantName   String
  contact         String
  note            String?
  status          String   @default("NEW")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([requesterUserId])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  actorUserId  String?
  actorUser    User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  hospitalId   String?
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unitId       String?
  unit         Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  action       String
  targetType   String
  targetId     String?
  beforeJson   Json?
  afterJson    Json?
  reason       String?
  ip           String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([actorUserId])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([unitId])
  @@index([action])
  @@index([createdAt])
}
